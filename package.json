{
  "name": "shadow-vault",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "wasm": "cd crate && wasm-pack build --target web --out-dir ../pkg --release && cp ../pkg/shadow_vault_crypto_bg.wasm ../public/ && cp ../pkg/shadow_vault_crypto.js ../public/",
    "test": "cd crate && cargo test --release",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "deploy": "gh-pages -d out"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "autoprefixer": "^10.4.27",
    "gh-pages": "^6.3.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  }
}
